{
  "name": "@radar-pro/api",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist --env=\"\"",
    "deploy": "wrangler deploy --env=\"\"",
    "db:migrate:local": "wrangler d1 migrations apply radar-pro-local --local",
    "db:migrations:list:local": "wrangler d1 migrations list radar-pro-local --local",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "clean": "rm -rf dist .wrangler"
  },
  "dependencies": {
    "@radar-pro/core": "workspace:*",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260710.1",
    "@radar-pro/eslint-config": "workspace:*",
    "@radar-pro/typescript-config": "workspace:*",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^4.14.0"
  }
}
