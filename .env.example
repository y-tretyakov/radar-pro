# Radar Pro — environment placeholders (Phase 0.2 / v0.1.1)
# Copy to .env / .dev.vars as needed. Never commit secrets.
# Local D1/R2/KV work via wrangler.toml placeholders + --local (no account required).

# --- Cloudflare account (optional; only for remote deploy / remote D1) ---
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=

# --- Workers / API ---
# API_BASE_URL=http://localhost:8787
# WORKER_NAME=radar-pro-worker
# API_NAME=radar-pro-api

# --- D1 (Entity Store) ---
# Local database_name (wrangler.toml): radar-pro-local
# D1_DATABASE_NAME=radar-pro-local
# D1_DATABASE_ID=00000000-0000-4000-8000-000000000001
# D1_BINDING=DB
# Preview / production names (placeholders until real resources exist):
# D1_DATABASE_NAME_PREVIEW=radar-pro-preview
# D1_DATABASE_NAME_PRODUCTION=radar-pro-production

# --- R2 journal ---
# Local bucket_name: radar-pro-journal-local
# R2_BUCKET_NAME=radar-pro-journal-local
# R2_BINDING=JOURNAL
# R2_BUCKET_NAME_PREVIEW=radar-pro-journal-preview
# R2_BUCKET_NAME_PRODUCTION=radar-pro-journal-production

# --- KV ---
# Local placeholder id in wrangler.toml
# KV_NAMESPACE_ID=00000000-0000-4000-8000-000000000002
# KV_BINDING=KV
# KV_NAMESPACE_ID_PREVIEW=00000000-0000-4000-8000-000000000012
# KV_NAMESPACE_ID_PRODUCTION=00000000-0000-4000-8000-000000000022

# --- Frontend (Vite) ---
# VITE_API_URL=http://localhost:8787

# --- GitHub (future connectors) ---
# GITHUB_TOKEN=
