# Radar Pro — environment placeholders (Phase 0.1 skeleton)
# Copy to .env / .dev.vars as needed. Never commit secrets.

# --- Cloudflare account (Phase 0.2+) ---
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=

# --- Workers / API ---
# API_BASE_URL=http://localhost:8787
# WORKER_NAME=radar-pro-worker
# API_NAME=radar-pro-api

# --- D1 (Phase 0.2+) ---
# D1_DATABASE_NAME=radar-pro-db
# D1_DATABASE_ID=

# --- R2 journal (Phase 0.2+) ---
# R2_BUCKET_NAME=radar-pro-journal
# R2_BUCKET_ID=

# --- KV (Phase 0.2+) ---
# KV_NAMESPACE_ID=

# --- Frontend (Vite) ---
# VITE_API_URL=http://localhost:8787

# --- GitHub (future connectors) ---
# GITHUB_TOKEN=
